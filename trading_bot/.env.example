# ── Binance Futures Testnet Credentials ──────────────────────────────────────
# Copy this file to .env and fill in your testnet credentials.
# NEVER commit your real .env file to version control.
#
# Get your keys from: https://testnet.binancefuture.com
#   1. Log in → click your profile → API Management
#   2. Generate a new key pair
#   3. Paste the values below

BINANCE_TESTNET_API_KEY=your_testnet_api_key_here
BINANCE_TESTNET_API_SECRET=your_testnet_api_secret_here
